{
	"compilerOptions": {
		"strict": true,
		"target": "ES2019",
		"lib": ["ES2019"],
		"module": "commonjs",
		"moduleResolution": "node",
		"outDir": "./dist",
		"rootDir": ".",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"skipLibCheck": true
	},
	"exclude": ["node_modules", "dist"],
	"include": ["credentials/**/*.ts", "nodes/**/*.ts"]
}
